@page
@model WebApp.Pages.Tournaments.IndexModel
@{
    ViewData["Title"] = "Gestão de Torneios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Torneios de E-Sports</h1>
    <a asp-page="Create" class="btn btn-primary">Criar Novo Torneio</a>
</div>

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Nome do Torneio</th>
            <th>Nome do Jogo</th>
            <th class="text-center">Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Tournaments)
        {
            <tr>
                <td class="align-middle">
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td class="align-middle">
                    @Html.DisplayFor(modelItem => item.GameName)
                </td>
                <td class="text-center align-middle">
                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a> |
                    <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Detalhes</a> |
                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>