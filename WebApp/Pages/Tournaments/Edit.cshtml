@page
@model WebApp.Pages.Tournaments.EditModel
@{
    ViewData["Title"] = "Editar Torneio";
}

<h1>Editar Torneio</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form method="post" class="card p-4 shadow-sm">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="Tournament.Id" />
            <input type="hidden" asp-for="Tournament.OwnerId" />
            <input type="hidden" asp-for="Tournament.IsManualOverride" />

            <div class="form-group mb-3">
                <label asp-for="Tournament.Name" class="control-label fw-bold"></label>
                <input asp-for="Tournament.Name" class="form-control" />
                <span asp-validation-for="Tournament.Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Tournament.GameName" class="control-label fw-bold"></label>
                <input asp-for="Tournament.GameName" class="form-control" />
                <span asp-validation-for="Tournament.GameName" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Tournament.PrizePoolAux" class="control-label fw-bold"></label>
                <input asp-for="Tournament.PrizePoolAux" class="form-control" />
                <span asp-validation-for="Tournament.PrizePoolAux" class="text-danger"></span>
            </div>

            <div class="form-group d-flex gap-2">
                <input type="submit" value="Guardar Alterações" class="btn btn-warning" />
                <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar e Voltar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}