@page
@model WebApp.Pages.Tournaments.DeleteModel
@{
    ViewData["Title"] = "Eliminar Torneio";
}

<h1 class="text-danger">Eliminar Torneio</h1>
<h3>Tem a certeza de que pretende eliminar este registo permanentemente?</h3>
<hr />

<div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

<div class="card border-danger shadow-sm mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-secondary">
                @Html.DisplayNameFor(model => model.Tournament.Name)
            </dt>
            <dd class="col-sm-9 fw-bold">
                @Html.DisplayFor(model => model.Tournament.Name)
            </dd>

            <dt class="col-sm-3 text-secondary">
                @Html.DisplayNameFor(model => model.Tournament.GameName)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Tournament.GameName)
            </dd>
        </dl>
    </div>
</div>

<form method="post" class="d-flex gap-2">
    <input type="hidden" asp-for="Tournament.Id" />

    <input type="submit" value="Confirmar Eliminação" class="btn btn-danger" />
    <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar e Voltar</a>
</form>