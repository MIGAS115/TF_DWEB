@page
@model WebApp.Pages.Tournaments.CreateModel
@{
    ViewData["Title"] = "Criar Torneio";
}

<h1>Criar Novo Torneio</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form method="post" class="card p-4 shadow-sm">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Tournament.Name" class="control-label fw-bold"></label>
                <input asp-for="Tournament.Name" class="form-control" placeholder="Ex: Campeonato Nacional" />
                <span asp-validation-for="Tournament.Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Tournament.GameName" class="control-label fw-bold"></label>
                <input asp-for="Tournament.GameName" class="form-control" placeholder="Ex: CS2" />
                <span asp-validation-for="Tournament.GameName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Tournament.PrizePoolAux" class="control-label fw-bold"></label>
                <input asp-for="Tournament.PrizePoolAux" class="form-control" placeholder="Ex: 5000,00 (Opcional)" />
                <span asp-validation-for="Tournament.PrizePoolAux" class="text-danger"></span>
            </div>

            <div class="form-group d-flex gap-2">
                <input type="submit" value="Guardar Torneio" class="btn btn-success" />
                <a asp-page="Index" class="btn btn-outline-secondary">Cancelar e Voltar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}