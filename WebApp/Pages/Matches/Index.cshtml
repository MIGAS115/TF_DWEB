@page
@model WebApp.Pages.Matches.IndexModel
@{
    ViewData["Title"] = "Gestão de Jogos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Jogos Agendados (Matches)</h1>
    <a asp-page="Create" class="btn btn-primary">Agendar Novo Jogo</a>
</div>

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Data do Jogo</th>
            <th>Equipa da Casa</th>
            <th>Equipa Visitante</th>
            <th>Torneio</th>
            <th class="text-center">Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Match)
        {
            <tr>
                <td class="align-middle">
                    @item.MatchDate.ToString("dd/MM/yyyy HH:mm")
                </td>
                <td class="align-middle fw-bold text-primary">
                    @item.HomeTeam?.Name
                </td>
                <td class="align-middle fw-bold text-danger">
                    @item.AwayTeam?.Name
                </td>
                <td class="align-middle">
                    @item.Tournament?.Name
                </td>
                <td class="text-center align-middle">
                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a> |
                    <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Detalhes</a> |
                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>