@page
@model WebApp.Pages.Matches.DeleteModel
@{
    ViewData["Title"] = "Cancelar Jogo";
}

<h1 class="text-danger">Eliminar Jogo Agendado</h1>
<h3>Tem a certeza de que pretende remover este jogo permanentemente da plataforma?</h3>
<hr />

<div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

<div class="card border-danger shadow-sm mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-secondary">Data e Hora</dt>
            <dd class="col-sm-9 fw-bold">@Model.Match.MatchDate.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3 text-secondary">Equipa da Casa</dt>
            <dd class="col-sm-9 text-primary fw-bold">@Html.DisplayFor(model => model.Match.HomeTeam.Name)</dd>

            <dt class="col-sm-3 text-secondary">Equipa Visitante</dt>
            <dd class="col-sm-9 text-danger fw-bold">@Html.DisplayFor(model => model.Match.AwayTeam.Name)</dd>

            <dt class="col-sm-3 text-secondary">Torneio</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Match.Tournament.Name)</dd>
        </dl>
    </div>
</div>

<form method="post" class="d-flex gap-2">
    <input type="hidden" asp-for="Match.Id" />
    <input type="submit" value="Confirmar Eliminação" class="btn btn-danger" />
    <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar e Voltar</a>
</form>