@page
@model WebApp.Pages.Matches.CreateModel
@{
    ViewData["Title"] = "Agendar Jogo";
}

<h1>Agendar Novo Jogo</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form method="post" class="card p-4 shadow-sm">
            <input type="hidden" asp-for="Match.OwnerId" value="0" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Match.MatchDate" class="control-label fw-bold">Data e Hora do Jogo</label>
                <input asp-for="Match.MatchDate" class="form-control" type="datetime-local" />
                <span asp-validation-for="Match.MatchDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Match.HomeTeamFK" class="control-label fw-bold">Equipa da Casa</label>
                <select asp-for="Match.HomeTeamFK" class="form-control" asp-items="ViewBag.HomeTeamFK">
                    <option value="">-- Selecione a Equipa da Casa --</option>
                </select>
                <span asp-validation-for="Match.HomeTeamFK" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Match.AwayTeamFK" class="control-label fw-bold">Equipa Visitante</label>
                <select asp-for="Match.AwayTeamFK" class="form-control" asp-items="ViewBag.AwayTeamFK">
                    <option value="">-- Selecione a Equipa Visitante --</option>
                </select>
                <span asp-validation-for="Match.AwayTeamFK" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Match.TournamentFK" class="control-label fw-bold">Torneio / Competição</label>
                <select asp-for="Match.TournamentFK" class="form-control" asp-items="ViewBag.TournamentFK">
                    <option value="">-- Selecione o Torneio --</option>
                </select>
                <span asp-validation-for="Match.TournamentFK" class="text-danger"></span>
            </div>

            <div class="form-group d-flex gap-2">
                <input type="submit" value="Agendar Jogo" class="btn btn-success" />
                <a asp-page="Index" class="btn btn-outline-secondary">Cancelar e Voltar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}