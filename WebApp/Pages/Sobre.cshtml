@page
@model WebApp.Pages.SobreModel
@{
    ViewData["Title"] = "Sobre o Projeto";
}

<div class="container mt-5 mb-5">
    <h1 class="display-6 fw-bold text-primary mb-4">Sobre o Projeto</h1>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100 p-4">
                <h4 class="fw-semibold border-bottom pb-2">Informação Académica</h4>
                <ul class="list-unstyled text-muted mt-3">
