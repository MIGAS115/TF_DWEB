                <ul class="list-unstyled text-muted mt-3">
                    <li><strong>Nº 25981</strong> - Miguel Araújo</li>
                    <li><strong>Nº 25954</strong> - Daniel Gonçalves</li>
                </ul>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100 p-4">

