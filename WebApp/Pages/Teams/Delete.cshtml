@page
@model WebApp.Pages.Teams.DeleteModel

@{
    ViewData["Title"] = "Eliminar Equipa";
}

<h1 class="text-danger">Eliminar Equipa</h1>
<h3>Tem a certeza de que pretende eliminar este registo permanentemente?</h3>
<hr />

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        <strong>Atenção!</strong> @Model.ErrorMessage
    </div>
}

<div class="card border-danger shadow-sm mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-secondary">
                @Html.DisplayNameFor(model => model.Team.Name)
            </dt>
            <dd class="col-sm-9 fw-bold">
                @Html.DisplayFor(model => model.Team.Name)
            </dd>

            <dt class="col-sm-3 text-secondary">
                Logótipo
            </dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrEmpty(Model.Team.LogoPath))
                {
                    <img src="~/images/teams/@Model.Team.LogoPath" alt="Logo da Equipa" class="img-thumbnail" style="max-height: 80px;" />
                }
                else
                {
                    <span class="text-muted">Sem logótipo associado</span>
                }
            </dd>
        </dl>
    </div>
</div>

<form method="post" class="d-flex gap-2">
    <input type="hidden" asp-for="Team.Id" />
    <input type="hidden" asp-for="Team.LogoPath" />
    <input type="hidden" asp-for="Team.OwnerId" />

    <input type="submit" value="Confirmar Eliminação" class="btn btn-danger" disabled="@(!string.IsNullOrEmpty(Model.ErrorMessage) ? "disabled" : null)" />
    <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar e Voltar</a>
</form>