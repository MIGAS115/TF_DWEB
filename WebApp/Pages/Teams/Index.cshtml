@page
@model WebApp.Pages.Teams.IndexModel
@{
    ViewData["Title"] = "Gestão de Equipas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Equipas de E-Sports</h1>

    @if (User.IsInRole("Admin") || User.IsInRole("Gestor"))
    {
        <a asp-page="Create" class="btn btn-primary">Registar Nova Equipa</a>
    }
</div>

<table class="table table-striped table-hover shadow-sm align-middle">
    <thead class="table-dark">
        <tr>
            <th style="width: 100px;" class="text-center">Logótipo</th>
            <th>Nome da Equipa</th>
            <th class="text-center">Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Teams)
        {
            <tr>
                <td class="text-center">
                    @if (!string.IsNullOrEmpty(item.LogoPath))
                    {
                        <img src="~/images/@item.LogoPath" alt="Logótipo de @item.Name" class="img-thumbnail" style="max-width: 50px; max-height: 50px;" />
                    }
                    else
                    {
                        <span class="badge bg-secondary">Sem Logo</span>
                    }
                </td>
                <td class="fw-bold fs-5">
                    @item.Name
                </td>
                <td class="align-middle">
                    <div class="d-flex align-items-center gap-2 justify-content-center">
                        @if (User.Identity?.IsAuthenticated == true && !User.IsInRole("Admin"))
                        {
                            <form method="post" asp-page-handler="ToggleFavorite" asp-route-teamId="@item.Id" style="display:inline; margin:0;">
                                @if (Model.UserFavoriteTeamIds.Contains(item.Id))
                                {
                                    <button type="submit" class="btn btn-sm btn-warning">★ Remover Favorito</button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-warning">☆ Adicionar Favorito</button>
                                }
                            </form>
                        }

                        <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Detalhes</a>

                        @if (Model.EditableTeamIds.Contains(item.Id))
                        {
                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Editar</a>
                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPaginas > 1)
{
    <nav class="d-flex justify-content-center mt-4">
        <ul class="pagination pagination-sm shadow-sm">
            <li class="page-item @(Model.PaginaAtual == 1 ? "disabled" : "")">
                <a class="page-link" asp-page="./Index" asp-route-paginaAtual="@(Model.PaginaAtual - 1)">Anterior</a>
            </li>
            @for (int i = 1; i <= Model.TotalPaginas; i++)
            {
                <li class="page-item @(Model.PaginaAtual == i ? "active" : "")">
                    <a class="page-link" asp-page="./Index" asp-route-paginaAtual="@i">@i</a>
                </li>
            }
            <li class="page-item @(Model.PaginaAtual == Model.TotalPaginas ? "disabled" : "")">
                <a class="page-link" asp-page="./Index" asp-route-paginaAtual="@(Model.PaginaAtual + 1)">Seguinte</a>
            </li>
        </ul>
    </nav>
}