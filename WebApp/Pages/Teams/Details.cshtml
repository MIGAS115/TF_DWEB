@page
@model WebApp.Pages.Teams.DetailsModel
@{
    ViewData["Title"] = "Detalhes da Equipa";
}

<h1>Detalhes da Equipa</h1>
<hr />

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-secondary">
                @Html.DisplayNameFor(model => model.Team.Name)
            </dt>
            <dd class="col-sm-9 fw-bold">
                @Html.DisplayFor(model => model.Team.Name)
            </dd>

            <dt class="col-sm-3 text-secondary">
                @Html.DisplayNameFor(model => model.Team.Category)
            </dt>
            <dd class="col-sm-9">
                @Model.Team.Category.Name
            </dd>

            <dt class="col-sm-3 text-secondary">
                Total de Partidas
            </dt>
            <dd class="col-sm-9 fw-bold text-primary">
                @Model.TotalMatches
            </dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-page="./Edit" asp-route-id="@Model.Team.Id" class="btn btn-warning">Editar Equipa</a>
    <a asp-page="./Index" class="btn btn-outline-secondary">Voltar à Listagem</a>
</div>